# ============================================================
# AuraLoom Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# Get these from your Supabase Dashboard → Settings → API

# YOUR OWN Supabase Project URL
# Example: https://your-project-id.supabase.co
#VITE_SUPABASE_URL=https://your-project-id.supabase.co

# YOUR OWN Supabase Anon/Public Key
#VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For production deployment (Netlify)
# Set this to your Netlify site URL
# VITE_SITE_URL=https://your-site-name.netlify.app

# ============================================================
# Netlify Function Environment Variables (set in Netlify Dashboard)
# Do NOT put these in .env — set them in Netlify UI
# ============================================================
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# RESEND_API_KEY=re_xxxx (optional, for email sending)

